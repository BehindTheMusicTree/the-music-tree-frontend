{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch app (dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "env": { "PORT": "3005" },
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch app (build and run)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "launch"],
      "cwd": "${workspaceFolder}",
      "env": { "PORT": "3005" },
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open app in Chrome",
      "url": "http://localhost:3005",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
