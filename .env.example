# Copy to `.env.local` and fill in values. Do not commit `.env.local`.
#
# Optional: higher GitHub API rate limits for the About page team (see README).
# Classic PAT with no scopes is enough for public endpoints.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Required: apex/root host without scheme (e.g. behindthemusictree.org). Used with single-label subdomains below.
DOMAIN_NAME=themusictree.org

# Optional: public site origin (https + host, no trailing slash). Used by the footer Website Carbon badge on localhost so the API can measure your production URL instead of http://localhost.
# NEXT_PUBLIC_SITE_ORIGIN=https://themusictree.org

# Required: each is a single label (e.g. api) or full host (api.example.com) or full URL. See src/lib/subdomain-urls.ts.
HTMT_API_SUBDOMAIN=hear-api
GTMT_FRONT_SUBDOMAIN=grow
AUDIOMETA_SUBDOMAIN=audiometa

# Required: full Mastodon profile URL (used on /contact; GitHub Actions → Vercel sync).
MASTODON_URL=https://mastodon.social/@andreas3000
