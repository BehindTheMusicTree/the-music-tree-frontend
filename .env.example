# Copy to `.env.local` and fill in values. Do not commit `.env.local`.
#
# Optional: higher GitHub API rate limits for the About page team (see README).
# Classic PAT with no scopes is enough for public endpoints.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Required: apex/root host without scheme (e.g. behindthemusictree.org). Used with single-label subdomains below.
DOMAIN_NAME=themusictree.org

# Public: same host as DOMAIN_NAME (no scheme). Builds links to Website Carbon’s /website/{host-with-dots-as-dashes}/
# report and sets the badge’s “Website Carbon” button href. GitHub → Vercel sync copies DOMAIN_NAME into this key.
NEXT_PUBLIC_ORG_URL=themusictree.org

# Optional (local dev only): https + host, no trailing slash. Footer Website Carbon badge: only used when
# hostname is localhost, 127.0.0.1, or *.local — the badge then measures NEXT_PUBLIC_SITE_ORIGIN + path/query
# (production URL) because api.websitecarbon.com cannot score http://localhost. Ignored on deployed hosts
# (production, Vercel previews): the badge uses the real page URL.
# NEXT_PUBLIC_SITE_ORIGIN=https://themusictree.org

# Optional: Website Carbon footer badge — set to 1 / true / yes to log [WebsiteCarbon] to the browser console
# on production/preview builds. (In `npm run dev`, logging is already enabled.)
# NEXT_PUBLIC_DEBUG_WEBSITE_CARBON=1

# Required: each is a single label (e.g. api) or full host (api.example.com) or full URL. See src/lib/subdomain-urls.ts.
HTMT_API_SUBDOMAIN=hear-api
GTMT_FRONT_SUBDOMAIN=grow
AUDIOMETA_SUBDOMAIN=audiometa

# Required: full Mastodon profile URL (used on /contact; GitHub Actions → Vercel sync).
MASTODON_URL=https://mastodon.social/@andreas3000
