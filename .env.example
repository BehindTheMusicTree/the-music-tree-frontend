# Copy to `.env.local` and fill in values. Do not commit `.env.local`.
#
# Optional: higher GitHub API rate limits for the About page team (see README).
# Classic PAT with no scopes is enough for public endpoints.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Required: apex/root host without scheme (e.g. behindthemusictree.org). Used with single-label subdomains; see src/lib/subdomain-urls.ts.
DOMAIN_NAME=themusictree.org

# Required: public org site host without scheme (Website Carbon /website/…/ links; footer + /engagement). Usually same as DOMAIN_NAME.
# GitHub → Vercel sync: set from repository Environment variable DOMAIN_NAME (synced to Vercel as ORG_URL). See src/lib/website-carbon-results-url.ts.
ORG_URL=themusictree.org

# Local development (localhost, 127.0.0.1, *.local): https + host, no trailing slash. Footer Website Carbon
# badge measures NEXT_PUBLIC_SITE_ORIGIN + path/query (public URL) because api.websitecarbon.com cannot score
# http://localhost. Ignored on deployed hosts (production, Vercel previews): the badge uses the real page URL.
# NEXT_PUBLIC_SITE_ORIGIN=https://themusictree.org

# Website Carbon footer badge: set to 1 / true / yes to log [WebsiteCarbon] to the browser console on
# production/preview builds. (In `npm run dev`, logging is already enabled.)
# NEXT_PUBLIC_DEBUG_WEBSITE_CARBON=1

# Required: each is a single label (e.g. api) or full host (api.example.com) or full URL. See src/lib/subdomain-urls.ts.
HTMT_API_SUBDOMAIN=hear-api
GTMT_FRONT_SUBDOMAIN=grow
AUDIOMETA_SUBDOMAIN=audiometa

# Required: full Mastodon profile URL (used on /contact; GitHub Actions → Vercel sync).
MASTODON_URL=https://mastodon.social/@andreas3000

# Required: Brevo Marketing API key (server-only). SMTP & API → API keys; contacts (+ templates for DOI).
# GitHub → Vercel: store as Environment secret BREVO_API_KEY; sync via .github/workflows/sync-vercel-env.yml
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Required: Brevo list id(s) for newsletter subscribers (Contacts → Lists). Comma-separated for multiple lists.
BREVO_NEWSLETTER_LIST_ID=1

# Required: numeric id of your double opt-in template (Campaigns → Templates → double opt-in).
# https://developers.brevo.com/reference/create-doi-contact
BREVO_DOI_TEMPLATE_ID=2

# Required: path on this site after the user confirms (Brevo gets https://DOMAIN_NAME + this path). GitHub: same var; sync copies it to Vercel.
BREVO_DOI_REDIRECT_PATH=/newsletter/confirmed
